{
  "name": "n8n-decanter",
  "version": "0.4.1",
  "description": "Work on n8n like a codebase — built for AI coding agents",
  "keywords": [
    "n8n",
    "workflow",
    "git",
    "sync",
    "cli",
    "code-node",
    "typescript",
    "agentic"
  ],
  "homepage": "https://github.com/buttjer/n8n-decanter#readme",
  "bugs": "https://github.com/buttjer/n8n-decanter/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buttjer/n8n-decanter.git"
  },
  "license": "MIT",
  "author": "Malte Buttjer (https://www.buttjer.net)",
  "type": "module",
  "bin": {
    "n8n-decanter": "./dist/n8n-decanter.mjs"
  },
  "files": [
    "dist/",
    "template/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "node scripts/setup-hooks.mts",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.cli.json && node scripts/typecheck.mts",
    "test": "node --test 'test/unit/*.test.mts' && node test/e2e.mts && node test/proxy.mts && node test/interactive.mts",
    "test:smoke": "node test/smoke-n8n.mts",
    "test:sim": "node test/sim.mts"
  },
  "engines": {
    "node": ">=22.18"
  },
  "dependencies": {
    "esbuild": "^0.28.1",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
