# Egress-allowlist proxy sidecar (Plan 35 container mode). The blind-agent
# container has NO direct internet (it sits on an --internal docker network); its
# ONLY route out is through this proxy, which forwards to api.anthropic.com and
# NOTHING else (FilterDefaultDeny). So even an injected/looping agent can't
# exfiltrate the API key or reach arbitrary hosts. Fail-closed: a misconfig means
# the agent can't reach Anthropic and the run dies, rather than leaking.
FROM alpine:3.20
RUN apk add --no-cache tinyproxy
COPY tinyproxy.conf /etc/tinyproxy/tinyproxy.conf
COPY anthropic-filter /etc/tinyproxy/filter
EXPOSE 8888
ENTRYPOINT ["tinyproxy", "-d", "-c", "/etc/tinyproxy/tinyproxy.conf"]
