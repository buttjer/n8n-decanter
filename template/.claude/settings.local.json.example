{
  "permissions": {
    "allow": [
      "Edit(workflows/**)",
      "Edit(shared/**)",
      "Bash(n8n-decanter check)",
      "Bash(n8n-decanter check:*)",
      "Bash(n8n-decanter node:*)",
      "Bash(n8n-decanter rename:*)",
      "Bash(n8n-decanter status)",
      "Bash(n8n-decanter status:*)",
      "Bash(n8n-decanter list)",
      "Bash(n8n-decanter list:*)",
      "Bash(n8n-decanter executions)",
      "Bash(n8n-decanter executions:*)",
      "Bash(n8n-decanter data-tables)",
      "Bash(n8n-decanter data-tables:*)",
      "Bash(n8n-decanter completion:*)",
      "Bash(n8n-decanter help)",
      "Bash(npm run typecheck)",
      "Bash(npm run check)"
    ],
    "deny": [
      "Edit(**/.decanter.json)",
      "Edit(**/*.remote.js)",
      "Read(.env)",
      "Edit(.env)",
      "Bash(n8n-decanter push --force)",
      "Bash(n8n-decanter push --force:*)",
      "Bash(node n8n-decanter.mts push --force)",
      "Bash(node n8n-decanter.mts push --force:*)",
      "Bash(n8n-decanter archive --force)",
      "Bash(n8n-decanter archive --force:*)",
      "Bash(node n8n-decanter.mts archive --force)",
      "Bash(node n8n-decanter.mts archive --force:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/verify.mjs" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/mcp-route-check.mjs" }
        ]
      }
    ]
  }
}
