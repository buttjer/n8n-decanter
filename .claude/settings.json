{
  "permissions": {
    "allow": [
      "Bash(node n8n-decanter.mts *)",
      "Bash(node test/*)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npm view *)",
      "Bash(npx tsc *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git --no-pager log *)",
      "Bash(git --no-pager diff *)",
      "Bash(git --no-pager branch)",
      "Bash(git --no-pager reflog:*)",
      "Bash(git worktree *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort *)",
      "Bash(cmp:*)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(jq *)",
      "Bash(command -v *)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(curl -sL https://raw.githubusercontent.com/n8n-io/*)",
      "Bash(curl -sL \"https://raw.githubusercontent.com/n8n-io/*\")",
      "Bash(curl -sL https://api.github.com/repos/n8n-io/*)",
      "Bash(curl -sL \"https://api.github.com/repos/n8n-io/*\")",
      "Bash(curl -s https://raw.githubusercontent.com/n8n-io/*)",
      "Bash(curl -s \"https://raw.githubusercontent.com/n8n-io/*\")",
      "Bash(curl -s https://api.github.com/repos/n8n-io/*)",
      "Bash(curl -s \"https://api.github.com/repos/n8n-io/*\")",
      "WebFetch(domain:docs.n8n.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git branch)",
      "Bash(git branch --list:*)",
      "Bash(git branch -a:*)",
      "Bash(git branch --contains:*)",
      "Bash(git branch --show-current)",
      "Bash(git tag --list:*)",
      "Bash(git push *)",
      "Bash(docker version *)",
      "Bash(cd:*)",
      "Bash(git config --get-regexp:*)",
      "Bash(gh api repos/buttjer/n8n-decanter/*)",
      "Bash(gh run watch:*)",
      "Bash(docker info:*)",
      "Bash(git pull --ff-only)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(gh api -X DELETE:*)",
      "Bash(gh api --method DELETE:*)",
      "Bash(gh repo delete:*)"
    ],
    "ask": [
      "Bash(gh pr merge:*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "*.npmjs.org",
        "docs.n8n.io",
        "raw.githubusercontent.com",
        "api.github.com",
        "github.com"
      ],
      "allowUnixSockets": [
        "~/.docker/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.npm"
      ]
    },
    "excludedCommands": [
      "docker *"
    ]
  }
}
