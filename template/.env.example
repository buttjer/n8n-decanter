# Copy to .env and fill in. .env is gitignored.
N8N_HOST=https://your-n8n.example.com

# Prefer a SCOPED API key (n8n → Settings → n8n API → Create) limited to the
# permissions this tool actually uses, not a full-access key — smaller blast
# radius if .env leaks:
#   workflow:read  workflow:list  workflow:update       (pull / status / push)
#   workflow:create  workflow:delete                     (create / delete)
#   workflow:activate  workflow:deactivate               (publish / unpublish)
#   execution:read  execution:list                       (executions)
#   dataTable:list  dataTable:read                        (data-tables — only
#   dataTableColumn:read  dataTableRow:read                while "dataTables" is on)
# A full-access key also works.
N8N_API_KEY=n8n_api_...
