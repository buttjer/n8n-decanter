# Blind-agent container (Plan 35 container mode). The nested `claude -p` runs
# HERE, not on the host: no host filesystem, no host env beyond ANTHROPIC_API_KEY,
# and egress fenced to api.anthropic.com (via the proxy sidecar) + the throwaway
# n8n (on the private field-test network). Built by run.mts before an unattended
# round; the decanter CLI is installed at RUNTIME from the stage's packed tarball
# (Linux-native — the host's macOS node_modules must never leak in; esbuild &c.
# are platform-specific), so this image stays generic across CLI versions.
FROM node:22-bookworm-slim

# git: the sync dir is a repo (pull/push auto-commit). tini: PID-1 signal reaping
# so `docker stop` is clean. curl: the netcheck probe. ca-certificates: TLS.
RUN apt-get update \
  && apt-get install -y --no-install-recommends git ca-certificates tini curl \
  && rm -rf /var/lib/apt/lists/*

# Claude Code CLI + `typescript` (the sync dir's devDep, matching
# template/package.json.example), installed globally as ROOT → /usr/local. The
# decanter CLI (baked into the per-run image, also as root) lands in the SAME
# prefix, so: n8n-decanter is on the standard PATH (survives a login shell's
# profile PATH reset) and `check`'s typecheck fallback resolver finds typescript
# beside it. The fence blocks the npm registry at runtime, so deps bake at build.
RUN npm install -g --no-audit --no-fund @anthropic-ai/claude-code typescript@^5.6.0

# Run as a non-root user — the container is the isolation boundary; least-privilege inside.
RUN useradd -m -u 1001 agent

# The /work/node_modules volume is INITIALIZED FROM THIS PATH, so create it here
# owned by `agent`. Otherwise Docker mounts the volume root-owned and the agent
# hits `EACCES: permission denied, mkdir '/work/node_modules/@esbuild'` — round-2
# S1 burned turns "fixing" exactly that harness bug instead of testing decanter.
RUN mkdir -p /work/node_modules && chown -R agent:agent /work
USER agent
WORKDIR /work

COPY --chown=agent:agent entrypoint.sh /usr/local/bin/entrypoint.sh
# Invoked via `sh` so the copied script needs no +x bit (Write-tool default 644).
ENTRYPOINT ["/usr/bin/tini", "--", "sh", "/usr/local/bin/entrypoint.sh"]
# Kept alive per scenario; each turn is a `docker exec … claude -p … --resume`.
CMD ["tail", "-f", "/dev/null"]
