# Copy to .env and fill in. .env is gitignored.
N8N_HOST=https://your-n8n.example.com

# Sync (pull / push / watch / status / publish / unpublish) and the MCP guard
# (mcp connect / mcp serve) ride n8n's MCP server. Preferred auth: OAuth — run
# `n8n-decanter init` once; it opens n8n's consent page and stores rotating
# credentials in a gitignored .decanter-auth.json. No token in this file.
# Headless/CI alternative: a bearer token minted in n8n → Settings → MCP →
# API key (takes precedence over the OAuth file when set):
#N8N_MCP_TOKEN=...

# OPTIONAL public API key — only for the surfaces MCP cannot serve
# (executions and data-table reads). Prefer a SCOPED key (n8n → Settings →
# n8n API → Create) limited to what the tool actually uses, not a
# full-access key — smaller blast radius if .env leaks:
#   workflow:list                                         (init's connection check)
#   execution:read  execution:list                        (executions)
#   dataTable:list  dataTable:read                        (data-tables — only
#   dataTableColumn:read  dataTableRow:read                while "dataTables" is on)
# A full-access key also works.
#N8N_API_KEY=n8n_api_...
