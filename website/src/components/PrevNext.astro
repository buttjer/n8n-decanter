---
import { flatDocs } from "../lib/nav";

interface Props {
  id: string;
}

const { id } = Astro.props;
const flat = await flatDocs();
const index = flat.findIndex((entry) => entry.id === id);
const prev = index > 0 ? flat[index - 1] : undefined;
const next = index >= 0 && index < flat.length - 1 ? flat[index + 1] : undefined;
---

<nav class="mt-12 flex justify-between gap-4 border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800">
  {
    prev ? (
      <a href={prev.href} class="text-accent-700 hover:underline dark:text-accent-300">
        ← {prev.title}
      </a>
    ) : (
      <span />
    )
  }
  {
    next ? (
      <a href={next.href} class="text-right text-accent-700 hover:underline dark:text-accent-300">
        {next.title} →
      </a>
    ) : (
      <span />
    )
  }
</nav>
