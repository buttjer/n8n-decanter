#!/usr/bin/env node
// PostToolUse verify hook. After an Edit/Write to a Code-node source file, run
// the offline `n8n-decanter check` (layout compliance + typecheck) and, on
// failure, feed the output back to the agent (exit 2 = blocking). No-op when the
// edit isn't a node file, or when the CLI isn't on PATH yet (fresh scaffold).
import { spawnSync } from "node:child_process";
import { existsSync, readFileSync } from "node:fs";
import path from "node:path";

let payload = {};
try {
  payload = JSON.parse(readFileSync(0, "utf8") || "{}");
} catch {
  process.exit(0);
}

const file = payload.tool_input?.file_path;
if (!file) process.exit(0);

// A node source file is a .ts/.js (not a .remote.js artifact) that lives in a
// workflow folder's code/ subdir — the .decanter.json sits in the parent
// (legacy layouts had it as a direct sibling).
const dir = path.dirname(file);
const stateDir = existsSync(path.join(dir, ".decanter.json"))
  ? dir
  : path.basename(dir) === "code" && existsSync(path.join(path.dirname(dir), ".decanter.json"))
    ? path.dirname(dir)
    : null;
const isNodeFile = /\.(ts|js)$/.test(file) && !file.endsWith(".remote.js") && stateDir !== null;
if (!isNodeFile) process.exit(0);

// Scope the check to the edited workflow. `check` matches on the workflow id
// stored in .decanter.json (NOT the folder name), so read the id from there;
// if the state file is unreadable, fall back to a project-wide check.
let workflowId;
try {
  workflowId = JSON.parse(readFileSync(path.join(stateDir, ".decanter.json"), "utf8")).workflowId;
} catch {}
const args = typeof workflowId === "string" && workflowId ? ["check", workflowId] : ["check"];
const res = spawnSync("n8n-decanter", args, { encoding: "utf8" });
if (res.error?.code === "ENOENT") process.exit(0); // CLI not installed yet — stay quiet

if (typeof res.status === "number" && res.status !== 0) {
  const out = ((res.stdout ?? "") + (res.stderr ?? "")).trim();
  console.error(`n8n-decanter check failed after editing ${path.basename(file)}:\n${out}`);
  process.exit(2);
}
process.exit(0);
