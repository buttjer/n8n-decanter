{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "moduleDetection": "force"
  },
  "include": [
    "n8n-globals.d.ts",
    "shared/**/*.ts",
    "shared/**/*.js",
    "workflows/**/*.ts",
    "workflows/**/*.js"
  ],
  "exclude": ["node_modules", "**/*.remote.js"]
}
