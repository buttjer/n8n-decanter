---
import BaseLayout from "../layouts/BaseLayout.astro";
import { href } from "../lib/url";
---

<BaseLayout title="Page not found · n8n-decanter">
  <main class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center">
    <p class="font-mono text-sm text-zinc-500 dark:text-zinc-400">404</p>
    <h1 class="mt-2 text-4xl tracking-tight">Page not found</h1>
    <p class="mt-4 text-zinc-600 dark:text-zinc-400">
      This page doesn't exist — it may have moved when the docs were reorganized.
    </p>
    <div class="mt-8 flex gap-4 text-sm">
      <a href={href("/")} class="text-accent-700 hover:underline dark:text-accent-300">Home</a>
      <a href={href("/docs/getting-started/installation/")} class="text-accent-700 hover:underline dark:text-accent-300">
        Documentation
      </a>
    </div>
  </main>
</BaseLayout>
